# Application
APP_NAME=ScholarFlow
APP_ENV=development
DEBUG=true

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=academic_pal
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/academic_pal

# Redis
REDIS_URL=redis://redis:6379/0

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=papers
MINIO_SECURE=false

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM Providers
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
OPENCODE_API_KEY=YOUR_OPENCODE_API_KEY_HERE
OPENCODE_API_BASE=https://opencode.ai/zen/go/v1
OPENCODE_ZEN_API_KEY=YOUR_OPENCODE_ZEN_API_KEY_HERE
OPENCODE_ZEN_API_BASE=https://opencode.ai/zen/v1
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OLLAMA_BASE_URL=http://ollama:11434

# LiteLLM
LITELLM_API_KEY=YOUR_LITELLM_API_KEY_HERE

# Academic APIs
SEMANTIC_SCHOLAR_API_KEY=YOUR_SEMANTIC_SCHOLAR_API_KEY_HERE
CROSSREF_EMAIL=your-email@example.com

# GROBID
GROBID_URL=http://grobid:8070

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
